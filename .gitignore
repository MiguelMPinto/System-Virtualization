# Ignore node modules
node_modules/

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore build outputs
dist/
build/
coverage/

# Allow CSS, images, HTML, EJS templates, JS, etc
!*.css
!*.png
!*.jpg
!*.jpeg
!*.gif
!*.svg
!*.ejs

# Allow everything inside tvschat-dev or outra pasta que precises
!/cw3/tvschat/
